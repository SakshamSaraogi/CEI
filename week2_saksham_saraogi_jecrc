 ts.sort_values(\"Date\").set_index(\"Date\")[\"Estimated_Deliveries\"].asfreq(\"MS\")\n\nprint(f\"Time series: {ts.index[0].date()} -> {ts.index[-1].date()}\")\nprint(f\"Length: {len(ts)} monthly observations\")\nts.head(6)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-30T13:36:50.343595Z","iopub.execute_input":"2026-05-30T13:36:50.343975Z","iopub.status.idle":"2026-05-30T13:36:50.362919Z","shell.execute_reply.started":"2026-05-30T13:36:50.343939Z","shell.execute_reply":"2026-05-30T13:36:50.36222Z"}},"outputs":[{"name":"stdout","text":"Time series: 2015-01-01 -> 2025-12-01\nLength: 132 monthly observations\n","output_type":"stream"},{"execution_count":100,"output_type":"execute_result","data":{"text/plain":"Date\n2015-01-01    183180\n2015-02-01    165053\n2015-03-01    184567\n2015-04-01    225623\n2015-05-01    184264\n2015-06-01    198787\nFreq: MS, Name: Estimated_Deliveries, dtype: int64"},"metadata":{}}],"execution_count":100},{"id":"5943a1d3","cell_type":"code","source":"# ── 14.2 Classical seasonal decomposition ────────────────────\ndecomp = seasonal_decompose(ts, model=\"multiplicative\", period=12)\n\nfig, axes = plt.subplots(4, 1, figsize=(16, 13), sharex=True)\n\ncomponents = [\n    (ts,              \"Original Series\",  DARK),\n    (decomp.trend,    \"Trend Component\",  RED),\n    (decomp.seasonal, \"Seasonal Component (period=12)\", BLUE),\n    (decomp.resid,    \"Residuals\",        GOLD),\n]\n\nfor ax, (series, title, color) in zip(axes, components):\n    ax.plot(series.index, series.values, color=color, lw=1.8)\n    ax.fill_between(series.index, series.values,\n                    alpha=0.15, color=color)\n    ax.set_title(title)\n    ax.yaxis.set_major_formatter(kfmt)\n\nfig.suptitle(\"Multiplicative Decomposition — Global Monthly Deliveries\",\n             fontsize=15, fontweight=\"bold\", color=DARK, y=1.01)\nplt.tight_layout()\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-30T13:36:50.3641Z","iopub.execute_input":"2026-05-30T13:36:50.36501Z","iopub.status.idle":"2026-05-30T13:36:51.120162Z","shell.execute_reply.started":"2026-05-30T13:36:50.364966Z","shell.execute_reply":"2026-05-30T13:36:51.118942Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1760x1430 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":101},{"id":"05be8e09","cell_type":"markdown","source":"## 15 · Stationarity\n\nA time series is **stationary** if its mean, variance, and autocorrelation are constant over time.\n\nARIMA/SARIMA require stationarity. We test with the **Augmented Dickey-Fuller (ADF) test**:\n- H₀ (null): series has a unit root (non-stationary)\n- If **p < 0.05** -> reject H₀ -> series is stationary ✅\n\n**Differencing** (subtracting previous value) is the standard fix for non-stationarity.\n","metadata":{}},{"id":"2d2006d3","cell_type":"code","source":"# ── 15.1 ADF test ─────────────────────────────────────────────\ndef adf_test(series, label):\n    result = adfuller(series.dropna(), autolag=\"AIC\")\n    stationary = result[1] < 0.05\n    print(f\"── ADF Test: {label} ──\")\n    print(f\"  Test statistic : {result[0]:.4f}\")\n    print(f\"  p-value        : {result[1]:.4f}\")\n    print(f\"  Critical (5%)  : {result[4]['5%']:.4f}\")\n    print(f\"  Result         : {'✅ STATIONARY' if stationary else '⚠️  NON-STATIONARY'}\")\n    print()\n    return stationary\n\nstat_orig = adf_test(ts,              \"Original series\")\nts_d1     = ts.diff().dropna()\nstat_d1   = adf_test(ts_d1,           \"First-differenced\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-30T13:36:51.121487Z","iopub.execute_input":"2026-05-30T13:36:51.121835Z","iopub.status.idle":"2026-05-30T13:36:51.154028Z","shell.execute_reply.started":"2026-05-30T13:36:51.1218Z","shell.execute_reply":"2026-05-30T13:36:51.152175Z"}},"outputs":[{"name":"stdout","text":"── ADF Test: Original series ──\n  Test statistic : -8.8810\n  p-value        : 0.0000\n  Critical (5%)  : -2.8840\n  Result         : ✅ STATIONARY\n\n── ADF Test: First-differenced ──\n  Test statistic : -7.0101\n  p-value        : 0.0000\n  Critical (5%)  : -2.8853\n  Result         : ✅ STATIONARY\n\n","output_type":"stream"}],"execution_count":102},{"id":"cf888a47","cell_type":"code","source":"# ── 15.2 Visualise stationarity ───────────────────────────────\nfig, axes = plt.subplots(2, 2, figsize=(16, 9))\n\n# Original vs differenced\naxes[0,0].plot(ts.index, ts.values, color=RED, lw=1.6)\naxes[0,0].set_title(\"Original Series (non-stationary)\")\naxes[0,0].yaxis.set_major_formatter(kfmt)\n\naxes[0,1].plot(ts_d1.index, ts_d1.values, color=BLUE, lw=1.4)\naxes[0,1].axhline(0, color=DARK, lw=1, linestyle=\"--\")\naxes[0,1].set_title(\"First-Differenced (stationary)\")\naxes[0,1].yaxis.set_major_formatter(kfmt)\n\n# ACF & PACF on differenced (used to pick ARIMA orders)\nplot_acf( ts_d1, lags=30, ax=axes[1,0], alpha=0.05, color=RED)\naxes[1,0].set_title(\"ACF — First-Differenced  (-> MA order q)\")\n\nplot_pacf(ts_d1, lags=30, ax=axes[1,1], alpha=0.05, method=\"ywm\", color=BLUE)\naxes[1,1].set_title(\"PACF — First-Differenced  (-> AR order p)\")\n\nfig.suptitle(\"Stationarity Analysis & Autocorrelation Diagnostics\",\n             fontsize=15, fontweight=\"bold\", color=DARK, y=1.01)\nplt.tight_layout()\nplt.show()\n\nprint(\n    \"How to read ACF/PACF:\"\n    \"ACF cuts off at lag q  -> MA(q) term\"\n    \"PACF cuts off at lag p -> AR(p) term\"\n    \"d=1 (one round of differencing made the series stationary)\"\n    \"Seasonal spike at lag 12 -> seasonal ARIMA -> SARIMA\"\n)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-30T13:36:51.1551Z","iopub.execute_input":"2026-05-30T13:36:51.155489Z","iopub.status.idle":"2026-05-30T13:36:52.039901Z","shell.execute_reply.started":"2026-05-30T13:36:51.155449Z","shell.execute_reply":"2026-05-30T13:36:52.038955Z"}},"outputs":[{"output_type":"display_data","data":{"