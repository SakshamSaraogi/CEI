# DriveWise RAG Configuration Template
# Copy this file to .env and configure keys/models

GEMINI_API_KEY=
INGESTION_VISION_MODEL=gemini-flash-lite-latest
QUERY_UNDERSTANDING_MODEL=gemini-flash-lite-latest
GENERATION_MODEL=gemini-flash-lite-latest
EVALUATION_MODEL=gemini-flash-lite-latest

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

LLM_PROVIDER=openrouter

# Set to true to run offline mock mode with pre-baked specification queries.
# Set to false to run live RAG generation using the Gemini API.
MOCK_LLM=true
